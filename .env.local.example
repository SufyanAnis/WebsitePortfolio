# Copy this file to `.env.local` and fill in real values. Anything
# left blank is hidden at render time so no broken links ship.

# ─── BRAND ────────────────────────────────────────────────────────
NEXT_PUBLIC_FOUNDER_NAME=Sufyan Anis
NEXT_PUBLIC_CITY=Karachi, Pakistan
NEXT_PUBLIC_SITE_URL=https://website-portfolio-kdli.vercel.app

# ─── CONTACT (CTA section + footer) ───────────────────────────────
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_HREF=

# ─── SOCIALS (footer pill row) ────────────────────────────────────
# Each is a full URL. Leave blank to hide that pill from the footer.
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_DRIBBBLE_URL=
NEXT_PUBLIC_BEHANCE_URL=
NEXT_PUBLIC_YOUTUBE_URL=
